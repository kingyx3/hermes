# /etc/hermes-agent/hermes.env  (rendered by CI from GitHub secrets)
#
# Root-owned, mode 0600. Loaded by the hermes-agent systemd unit via
# EnvironmentFile=. Contains ONLY the runtime environment variables Hermes
# needs. NEVER committed, NEVER synced back to GitHub, NEVER printed in logs.
#
# Placeholders (${...}) are substituted with `envsubst` on the GitHub Actions
# runner before the file is copied to the VM.

# Gemini credentials. Hermes checks both names; we set both for compatibility.
GEMINI_API_KEY=${GEMINI_API_KEY}
GOOGLE_API_KEY=${GEMINI_API_KEY}

# Hermes runtime locations.
HERMES_HOME=${HERMES_CONFIG_DIR}
HERMES_WORKSPACE=${WORKSPACE_DIR}
